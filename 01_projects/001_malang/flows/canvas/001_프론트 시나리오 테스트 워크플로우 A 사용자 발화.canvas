	"nodes":[
		{"id":"t","type":"text","text":"# 기능 A\n사용자 발화 -> 슬롯 판정 -> user.final","x":220,"y":-120,"width":520,"height":120,"color":"4"},
		{"id":"s1","type":"text","text":"1) speech_started\n- output_audio_buffer.clear\n- 필요 시 response_cancel\n- silence/watchdog reset","x":260,"y":40,"width":440,"height":170,"color":"2"},
		{"id":"s2","type":"text","text":"2) input_audio_transcription.completed\n- transcript trim\n- empty면 return","x":260,"y":250,"width":440,"height":140,"color":"2"},
		{"id":"s3","type":"text","text":"3) 가드\n- speech_started 누락 fallback\n- low-signal 필터\n- dedupe window","x":260,"y":430,"width":440,"height":160,"color":"2"},
		{"id":"s4","type":"text","text":"4) requestSlotDetectionForTurn\n- pendingStages 계산\n- slot_detection response.create\n- pendingUserTurn 저장","x":260,"y":630,"width":440,"height":180,"color":"4"},
		{"id":"s5","type":"text","text":"5) response.done(purpose=slot_detection)\n-> parseSlotDetectionResult","x":260,"y":850,"width":440,"height":130,"color":"4"},
