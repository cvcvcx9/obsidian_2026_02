		{"id":"fail","type":"text","text":"파싱 실패\n- detectAttempt < max: 재시도\n- else detect.parse_fail","x":260,"y":1040,"width":440,"height":140,"color":"1"},
		{"id":"end1","type":"text","text":"applyFsmActions","x":-180,"y":1260,"width":280,"height":90,"color":"3"},
